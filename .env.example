# AWS Configuration
AWS_REGION=ap-south-1
AWS_ACCOUNT_ID=your-account-id

# DynamoDB
DYNAMODB_SESSIONS_TABLE=rti-sessions-dev
DYNAMODB_CONSENT_TABLE=rti-consent-dev

# S3
S3_DOCUMENTS_BUCKET=rti-documents-bucket-dev-{id}
S3_KNOWLEDGE_BASE_BUCKET=rti-knowledge-base-dev-{id}

# API Gateway
API_GATEWAY_URL=https://your-api-id.execute-api.ap-south-1.amazonaws.com/prod

# Amazon Bedrock
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_REGION=ap-south-1

# AWS Polly
POLLY_VOICE_HINDI=Aditi
POLLY_VOICE_ENGLISH=Joanna

# Lambda Configuration
LAMBDA_TIMEOUT=900
LAMBDA_MEMORY=10240

# Session Configuration
SESSION_TTL_HOURS=24

# Frontend (Next.js)
NEXT_PUBLIC_API_URL=https://your-api-id.execute-api.ap-south-1.amazonaws.com/prod
NEXT_PUBLIC_WS_URL=wss://your-ws-id.execute-api.ap-south-1.amazonaws.com/prod

# Development
NODE_ENV=development
LOG_LEVEL=INFO
